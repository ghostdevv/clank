{
	"name": "@rlly/clank",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"lint": "prettier --check . && oxlint --type-aware && tsc --noEmit",
		"fix": "prettier --write . && oxlint --type-aware --fix",
		"start": "pi --no-extensions --no-themes --extension ."
	},
	"pi": {
		"extensions": [
			"./src/extensions"
		],
		"themes": [
			"./src/themes"
		]
	},
	"dependencies": {
		"dedent": "^1.7.2",
		"node-html-markdown": "^2.0.0",
		"typebox": "^1.1.24"
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "^0.70.6",
		"@mariozechner/pi-coding-agent": "^0.71.0",
		"@mariozechner/pi-tui": "^0.71.0"
	},
	"devDependencies": {
		"@e18e/eslint-plugin": "^0.4.1",
		"@rlly/pedantic": "^0.3.0",
		"@types/node": "^25.6.0",
		"oxlint": "^1.62.0",
		"oxlint-tsgolint": "^0.22.1",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3"
	},
	"packageManager": "pnpm@11.0.1",
	"volta": {
		"node": "24.15.0",
		"pnpm": "11.0.1"
	}
}
